# Copy this file to .env.local and fill only the services you want to enable.
# Do not put platform passwords here. Use API keys, OAuth tokens, or exported CSV files.

# Optional higher GitHub API limits.
GITHUB_TOKEN=

# Optional official API collectors.
YOUTUBE_API_KEY=
X_BEARER_TOKEN=
TWITTER_BEARER_TOKEN=
PRODUCTHUNT_TOKEN=
PATENTSVIEW_API_KEY=
DOMAINSDB_API_KEY=

# Google demand data.
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_REFRESH_TOKEN=
GOOGLE_ADS_CUSTOMER_ID=

# Amazon Product Advertising API.
AMAZON_ACCESS_KEY=
AMAZON_SECRET_KEY=
AMAZON_PARTNER_TAG=
AMAZON_MARKETPLACE=www.amazon.com

# eBay Browse API.
EBAY_CLIENT_ID=
EBAY_CLIENT_SECRET=
EBAY_OAUTH_TOKEN=

# Etsy Open API.
ETSY_API_KEY=
ETSY_SHARED_SECRET=

# China ecommerce official/open-platform credentials.
TAOBAO_APP_KEY=
TAOBAO_APP_SECRET=
TAOBAO_SESSION=
JD_APP_KEY=
JD_APP_SECRET=
JD_ACCESS_TOKEN=

# Paid intelligence providers.
SIMILARWEB_API_KEY=
AHREFS_API_KEY=
G2_API_KEY=
CAPTERRA_API_KEY=
