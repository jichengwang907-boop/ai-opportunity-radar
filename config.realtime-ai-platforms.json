  "collector": {
    "enabled_sources": [
      "github",
      "github_issues",
      "producthunt",
      "arxiv",
      "huggingface_models",
      "huggingface_spaces",
      "hackernews",
      "reddit",
      "google_news",
      "agentic_engineering_jobs",
      "agentdeals",
      "oksurf_news",
      "api_status_check",
      "nvd",
      "youtube"
    ],
    "hits_per_source": 5,
    "request_timeout_seconds": 40,
    "retry_attempts": 4,
    "max_failures_per_source": 2,
    "max_failures_by_source": {
      "arxiv": 3
    },
    "failure_cooldown_by_source": {
      "arxiv": 180,
      "agentic_engineering_jobs": 20,
      "agentdeals": 20
    },
    "github_issues_filter": {
      "enabled": true,
      "overfetch_factor": 10,
      "max_fetch_per_query": 50,
      "keep_if_comments_at_least": 3,
      "effective_total_strategy": "sample_ratio",
      "require_demand_hint": true
    },
    "request_delay_seconds": 0.25,
    "request_delay_by_source": {
      "github": 0.5,
      "github_issues": 0.75,
      "producthunt": 0.5,
      "arxiv": 30,
      "huggingface_models": 0.5,
      "huggingface_spaces": 0.5,
      "hackernews": 0.25,
      "reddit": 1,
      "google_news": 0.5,
      "ai_dev_jobs": 0.5,
      "agentic_engineering_jobs": 1,
      "agentdeals": 1,
      "oksurf_news": 0,
      "api_status_check": 0,
      "nvd": 0,
      "youtube": 0.5
    },
    "raw_dir": "data/raw/realtime-ai",
    "search_results_path": "data/search_results.realtime-ai.csv",
